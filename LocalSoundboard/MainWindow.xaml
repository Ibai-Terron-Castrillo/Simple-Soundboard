<Window x:Class="LocalSoundboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LocalSoundboard"
        Height="760"
        Width="1180"
        MinHeight="680"
        MinWidth="1040"
        Background="#F6F7F9"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#20242A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#65707D" />
        <SolidColorBrush x:Key="LineBrush" Color="#D8DEE6" />
        <SolidColorBrush x:Key="AccentBrush" Color="#108A8A" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#087272" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B8323B" />
        <SolidColorBrush x:Key="FavoriteBrush" Color="#D97706" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#E8ECEF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="40" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="FavoriteButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Content" Value="☆" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                    <Setter Property="Content" Value="★" />
                    <Setter Property="Foreground" Value="{StaticResource FavoriteBrush}" />
                    <Setter Property="Background" Value="#FFF4DE" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="LocalSoundboard"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LibraryStatusText}"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Carpeta"
                            Command="{Binding BrowseFolderCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,10,0" />
                    <Button Content="Refrescar"
                            Command="{Binding RescanCommand}"
                            Margin="0,0,10,0" />
                    <Button Content="Stop All"
                            Command="{Binding StopAllCommand}"
                            Style="{StaticResource DangerButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,18,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Buscar" Style="{StaticResource LabelText}" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="15"
                             ToolTip="Busca por nombre, carpeta o etiqueta." />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Carpeta" Style="{StaticResource LabelText}" />
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Vista" Style="{StaticResource LabelText}" />
                    <ComboBox ItemsSource="{Binding QuickFilters}"
                              SelectedItem="{Binding SelectedQuickFilter}" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,18,0"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <ListBox ItemsSource="{Binding SoundsView}"
                         SelectedItem="{Binding SelectedSound}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="10,8"
                                    Padding="12"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Background="#FFFFFF">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                <Setter Property="Opacity" Value="0.52" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="Play"
                                            Style="{StaticResource PrimaryButton}"
                                            MinWidth="72"
                                            IsEnabled="{Binding IsAvailable}"
                                            Command="{Binding DataContext.PlaySoundCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />

                                    <StackPanel Grid.Column="1" Margin="14,0,12,0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding RelativePath}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding TagsText}"
                                                   Foreground="{StaticResource AccentDarkBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Background="#EEF1F4"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Extension}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </Border>

                                    <Button Grid.Column="3"
                                            Style="{StaticResource FavoriteButton}"
                                            Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Marcar favorito" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <StackPanel Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="1">
                <Border Background="#FFFFFF"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Salida de audio"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="Dispositivo" Style="{StaticResource LabelText}" />
                        <DockPanel Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right"
                                    Content="↻"
                                    Style="{StaticResource IconButton}"
                                    Command="{Binding RefreshDevicesCommand}"
                                    Margin="8,0,0,0"
                                    ToolTip="Actualizar dispositivos" />
                            <ComboBox ItemsSource="{Binding OutputDevices}"
                                      SelectedItem="{Binding SelectedOutputDevice}"
                                      DisplayMemberPath="DisplayName" />
                        </DockPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Volumen" Style="{StaticResource LabelText}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding VolumePercentText}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" />
                        </Grid>

                        <Slider Minimum="0"
                                Maximum="1"
                                TickFrequency="0.05"
                                Value="{Binding Volume, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,0,14" />

                        <TextBlock Text="Modo de reproduccion" Style="{StaticResource LabelText}" />
                        <ComboBox ItemsSource="{Binding PlaybackModeOptions}"
                                  SelectedItem="{Binding SelectedPlaybackModeOption}"
                                  DisplayMemberPath="Label" />
                    </StackPanel>
                </Border>

                <Border Background="#FFFFFF"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Seleccion"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="{Binding SelectedSound.Name, TargetNullValue=Selecciona un sonido}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5" />
                        <TextBlock Text="{Binding SelectedSound.RelativePath}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="Etiquetas" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding SelectedSound.TagsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False"
                                 ToolTip="Separa etiquetas con coma." />
                        <Button Content="Guardar etiquetas"
                                Command="{Binding SaveTagsCommand}"
                                Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#FFFFFF"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Control remoto"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <CheckBox Content="Activar servidor remoto"
                                  IsChecked="{Binding RemoteServerEnabled}"
                                  Margin="0,0,0,8" />
                        <CheckBox Content="Iniciar automaticamente"
                                  IsChecked="{Binding StartRemoteServerAutomatically}"
                                  Margin="0,0,0,12" />
                        <TextBlock Text="Puerto" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding ServerPort, UpdateSourceTrigger=LostFocus}"
                                 Margin="0,0,0,10" />
                        <TextBlock Text="PIN opcional" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding RemotePin, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12" />
                        <TextBlock Text="{Binding RemoteStatusText}"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding RemoteUrl}"
                                   Foreground="{StaticResource AccentDarkBrush}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0"
                Padding="22,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <TextBlock Text="{Binding AvailableSoundCount, StringFormat={}{0} disponibles}"
                               Margin="0,0,18,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding FavoriteSoundCount, StringFormat={}{0} favoritos}"
                               Margin="0,0,18,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalSoundCount, StringFormat={}{0} totales}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
