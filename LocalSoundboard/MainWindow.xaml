<Window x:Class="LocalSoundboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LocalSoundboard"
        Height="760"
        Width="1180"
        MinHeight="680"
        MinWidth="1040"
        Background="#F4F6F8"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#17212B" />
        <SolidColorBrush x:Key="MutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="LineBrush" Color="#D7DEE8" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#EEF2F6" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#B91C1C" />
        <SolidColorBrush x:Key="FavoriteBrush" Color="#D97706" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="11,8" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="#E7ECF2" />
            <Setter Property="BorderBrush" Value="#E7ECF2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DDE5EE" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#DDE5EE" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#CBD5E1" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FavoriteButton" TargetType="Button" BasedOn="{StaticResource SmallButton}">
            <Setter Property="Content" Value="Fav" />
            <Setter Property="MinWidth" Value="62" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                    <Setter Property="Content" Value="Saved" />
                    <Setter Property="Foreground" Value="{StaticResource FavoriteBrush}" />
                    <Setter Property="Background" Value="#FFF4DE" />
                    <Setter Property="BorderBrush" Value="#F8D8A5" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EAF2FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="LocalSoundboard"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LibraryStatusText}"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Choose Folder"
                            Command="{Binding BrowseFolderCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,10,0" />
                    <Button Content="Rescan"
                            Command="{Binding RescanCommand}"
                            Margin="0,0,10,0" />
                    <Button Content="Stop All"
                            Command="{Binding StopAllCommand}"
                            Style="{StaticResource DangerButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,18,16"
                    Style="{StaticResource PanelBorder}"
                    Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Search" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15"
                                 ToolTip="Search by name, folder, or tag." />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Folder" Style="{StaticResource LabelText}" />
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="View" Style="{StaticResource LabelText}" />
                        <ComboBox ItemsSource="{Binding QuickFilters}"
                                  SelectedItem="{Binding SelectedQuickFilter}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,18,0"
                    Style="{StaticResource PanelBorder}"
                    Padding="8">
                <ListBox ItemsSource="{Binding SoundsView}"
                         SelectedItem="{Binding SelectedSound}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="6"
                                    Padding="12"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Background="{StaticResource SurfaceBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                <Setter Property="Opacity" Value="0.52" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="Play"
                                            Style="{StaticResource PrimaryButton}"
                                            MinWidth="70"
                                            IsEnabled="{Binding IsAvailable}"
                                            Command="{Binding DataContext.PlaySoundCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />

                                    <StackPanel Grid.Column="1" Margin="14,0,12,0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding RelativePath}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding TagsText}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Background="{StaticResource SubtleBrush}"
                                            CornerRadius="5"
                                            Padding="8,4"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Extension}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </Border>

                                    <Button Grid.Column="3"
                                            Style="{StaticResource FavoriteButton}"
                                            Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Toggle favorite" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <StackPanel Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="1">
                <Border Style="{StaticResource PanelBorder}"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Audio Output"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="Device" Style="{StaticResource LabelText}" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding OutputDevices}"
                                      SelectedItem="{Binding SelectedOutputDevice}"
                                      DisplayMemberPath="DisplayName" />
                            <Button Grid.Column="1"
                                    Content="Reload"
                                    Style="{StaticResource SmallButton}"
                                    Command="{Binding RefreshDevicesCommand}"
                                    Margin="8,0,0,0"
                                    ToolTip="Refresh audio devices" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Volume" Style="{StaticResource LabelText}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding VolumePercentText}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" />
                        </Grid>

                        <Slider Minimum="0"
                                Maximum="1"
                                TickFrequency="0.05"
                                Value="{Binding Volume, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,0,14" />

                        <TextBlock Text="Playback mode" Style="{StaticResource LabelText}" />
                        <ComboBox ItemsSource="{Binding PlaybackModeOptions}"
                                  SelectedItem="{Binding SelectedPlaybackModeOption}"
                                  DisplayMemberPath="Label" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Selection"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="{Binding SelectedSound.Name, TargetNullValue='Select a sound'}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5" />
                        <TextBlock Text="{Binding SelectedSound.RelativePath}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="Tags" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding SelectedSound.TagsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False"
                                 ToolTip="Separate tags with commas." />
                        <Button Content="Save Tags"
                                Command="{Binding SaveTagsCommand}"
                                Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}">
                    <StackPanel>
                        <TextBlock Text="Remote Control"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <CheckBox Content="Remote server"
                                  IsChecked="{Binding RemoteServerEnabled}" />
                        <CheckBox Content="Start automatically"
                                  IsChecked="{Binding StartRemoteServerAutomatically}"
                                  Margin="0,0,0,12" />
                        <TextBlock Text="Port" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding ServerPort, UpdateSourceTrigger=LostFocus}"
                                 Margin="0,0,0,10" />
                        <TextBlock Text="Optional PIN" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding RemotePin, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12" />
                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="10">
                            <StackPanel>
                                <TextBlock Text="{Binding RemoteStatusText}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding RemoteUrl}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Border Background="{StaticResource SubtleBrush}"
                            CornerRadius="5"
                            Padding="9,4"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding AvailableSoundCount, StringFormat={}{0} available}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Background="{StaticResource SubtleBrush}"
                            CornerRadius="5"
                            Padding="9,4"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding FavoriteSoundCount, StringFormat={}{0} favorites}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Background="{StaticResource SubtleBrush}"
                            CornerRadius="5"
                            Padding="9,4">
                        <TextBlock Text="{Binding TotalSoundCount, StringFormat={}{0} total}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
