<Window x:Class="LocalSoundboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LocalSoundboard"
        Height="760"
        Width="1180"
        MinHeight="680"
        MinWidth="1040"
        Background="{DynamicResource WindowBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="TextBrush" Color="#17212B" />
        <SolidColorBrush x:Key="MutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="LineBrush" Color="#D7DEE8" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#EEF2F6" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#E7ECF2" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#DDE5EE" />
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#B91C1C" />
        <SolidColorBrush x:Key="FavoriteBrush" Color="#D97706" />
        <SolidColorBrush x:Key="FavoriteBackgroundBrush" Color="#FFF4DE" />
        <SolidColorBrush x:Key="FavoriteBorderBrush" Color="#F8D8A5" />
        <SolidColorBrush x:Key="SelectedItemBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="RemoteInfoBrush" Color="#EFF6FF" />
        <SolidColorBrush x:Key="RemoteInfoBorderBrush" Color="#BFDBFE" />
        <SolidColorBrush x:Key="IconBrush" Color="#17212B" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="11,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,0,38,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="7"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="34" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="{DynamicResource MutedBrush}"
                                                      StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SubtleBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <TextBlock x:Name="ContentSite"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                       HorizontalAlignment="Stretch"
                                       IsHitTestVisible="False"
                                       Margin="{TemplateBinding Padding}"
                                       Text="{TemplateBinding SelectionBoxItem}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       VerticalAlignment="Center" />

                            <Popup x:Name="Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Grid MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="7"
                                            Margin="0,4,0,0"
                                            SnapsToDevicePixels="True">
                                        <ScrollViewer Margin="4"
                                                      SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedItemBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="{DynamicResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonPressedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FavoriteButton" TargetType="Button" BasedOn="{StaticResource SmallButton}">
            <Setter Property="Content" Value="Fav" />
            <Setter Property="MinWidth" Value="62" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                    <Setter Property="Content" Value="Saved" />
                    <Setter Property="Foreground" Value="{DynamicResource FavoriteBrush}" />
                    <Setter Property="Background" Value="{DynamicResource FavoriteBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource FavoriteBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SelectedItemBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid TextElement.Foreground="{DynamicResource TextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="LocalSoundboard"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LibraryStatusText}"
                               Foreground="{DynamicResource MutedBrush}"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Command="{Binding ToggleThemeCommand}"
                            ToolTip="Toggle light and dark mode"
                            Margin="0,0,10,0"
                            MinWidth="92">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="16"
                                  Height="16"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center">
                                <Path Data="M8,3.2 A4.8,4.8 0,1 1 8,12.8 A4.8,4.8 0,1 1 8,3.2"
                                      Stroke="{DynamicResource IconBrush}"
                                      StrokeThickness="1.6"
                                      Fill="Transparent">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Data="M8,0.8 L8,2.1 M8,13.9 L8,15.2 M0.8,8 L2.1,8 M13.9,8 L15.2,8 M2.9,2.9 L3.8,3.8 M12.2,12.2 L13.1,13.1 M13.1,2.9 L12.2,3.8 M3.8,12.2 L2.9,13.1"
                                      Stroke="{DynamicResource IconBrush}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Data="M12.9,10.4 C11.8,11.3 10.4,11.8 8.9,11.8 C5.7,11.8 3.2,9.3 3.2,6.1 C3.2,4.6 3.7,3.2 4.6,2.1 C2.3,2.8 0.8,4.9 0.8,7.3 C0.8,10.5 3.5,13.2 6.7,13.2 C9.1,13.2 11.2,11.7 12.9,10.4 Z"
                                      Stroke="{DynamicResource IconBrush}"
                                      StrokeThickness="1.6"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Grid>
                            <TextBlock Text="{Binding ThemeToggleText}"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Content="Choose Folder"
                            Command="{Binding BrowseFolderCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,10,0" />
                    <Button Content="Rescan"
                            Command="{Binding RescanCommand}"
                            Margin="0,0,10,0" />
                    <Button Content="Stop All"
                            Command="{Binding StopAllCommand}"
                            Style="{StaticResource DangerButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,18,16"
                    Style="{StaticResource PanelBorder}"
                    Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Search" Style="{StaticResource LabelText}" />
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15"
                                 ToolTip="Search by name, folder, or tag." />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Folder" Style="{StaticResource LabelText}" />
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="View" Style="{StaticResource LabelText}" />
                        <ComboBox ItemsSource="{Binding QuickFilters}"
                                  SelectedItem="{Binding SelectedQuickFilter}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,18,0"
                    Style="{StaticResource PanelBorder}"
                    Padding="8">
                <ListBox ItemsSource="{Binding SoundsView}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectedItem="{Binding SelectedSound}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="6"
                                    Padding="12"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Background="{DynamicResource SurfaceBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                <Setter Property="Opacity" Value="0.52" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="Play"
                                            Style="{StaticResource PrimaryButton}"
                                            MinWidth="70"
                                            IsEnabled="{Binding IsAvailable}"
                                            Command="{Binding DataContext.PlaySoundCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />

                                    <StackPanel Grid.Column="1" Margin="14,0,12,0">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding RelativePath}"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding TagsText}"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Background="{DynamicResource SubtleBrush}"
                                            CornerRadius="5"
                                            Padding="8,4"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Extension}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedBrush}" />
                                    </Border>

                                    <Button Grid.Column="3"
                                            Style="{StaticResource FavoriteButton}"
                                            Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Toggle favorite" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <ScrollViewer Grid.Row="0"
                          Grid.RowSpan="2"
                          Grid.Column="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource PanelBorder}"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Audio Output"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />

                            <TextBlock Text="Device" Style="{StaticResource LabelText}" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding OutputDevices}"
                                          SelectedItem="{Binding SelectedOutputDevice}"
                                          DisplayMemberPath="DisplayName" />
                                <Button Grid.Column="1"
                                        Content="Reload"
                                        Style="{StaticResource SmallButton}"
                                        Command="{Binding RefreshDevicesCommand}"
                                        Margin="8,0,0,0"
                                        ToolTip="Refresh audio devices" />
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Volume" Style="{StaticResource LabelText}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding VolumePercentText}"
                                           Foreground="{DynamicResource MutedBrush}"
                                           FontSize="12" />
                            </Grid>

                            <Slider Minimum="0"
                                    Maximum="1"
                                    TickFrequency="0.05"
                                    Value="{Binding Volume, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,14" />

                            <TextBlock Text="Playback mode" Style="{StaticResource LabelText}" />
                            <ComboBox ItemsSource="{Binding PlaybackModeOptions}"
                                      SelectedItem="{Binding SelectedPlaybackModeOption}"
                                      DisplayMemberPath="Label" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorder}"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Selection"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />
                            <TextBlock Text="{Binding SelectedSound.Name, TargetNullValue='Select a sound'}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5" />
                            <TextBlock Text="{Binding SelectedSound.RelativePath}"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="12"
                                       Margin="0,0,0,12" />

                            <TextBlock Text="Tags" Style="{StaticResource LabelText}" />
                            <TextBox Text="{Binding SelectedSound.TagsText, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="False"
                                     ToolTip="Separate tags with commas." />
                            <Button Content="Save Tags"
                                    Command="{Binding SaveTagsCommand}"
                                    Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="Remote Control"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />
                            <CheckBox Content="Remote server"
                                      IsChecked="{Binding RemoteServerEnabled}" />
                            <CheckBox Content="Start automatically"
                                      IsChecked="{Binding StartRemoteServerAutomatically}"
                                      Margin="0,0,0,12" />
                            <TextBlock Text="Port" Style="{StaticResource LabelText}" />
                            <TextBox Text="{Binding ServerPort, UpdateSourceTrigger=LostFocus}"
                                     Margin="0,0,0,10" />
                            <TextBlock Text="Optional PIN" Style="{StaticResource LabelText}" />
                            <TextBox Text="{Binding RemotePin, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RemoteInfoBrush}"
                                    BorderBrush="{DynamicResource RemoteInfoBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding RemoteStatusText}"
                                               Foreground="{DynamicResource MutedBrush}"
                                               FontSize="12"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding RemoteUrl}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource MutedBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Border Background="{DynamicResource SubtleBrush}"
                            CornerRadius="5"
                            Padding="9,4"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding AvailableSoundCount, StringFormat={}{0} available}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Background="{DynamicResource SubtleBrush}"
                            CornerRadius="5"
                            Padding="9,4"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding FavoriteSoundCount, StringFormat={}{0} favorites}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Background="{DynamicResource SubtleBrush}"
                            CornerRadius="5"
                            Padding="9,4">
                        <TextBlock Text="{Binding TotalSoundCount, StringFormat={}{0} total}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
